---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  name: string;
  size?: 16 | 20 | 24;
  class?: string;
  ariaLabel?: string;
}

const { name, size = 20, class: cls = '', ariaLabel } = Astro.props;

const svgPath = path.join(
  process.cwd(),
  'node_modules/@phosphor-icons/core/assets/regular',
  `${name}.svg`,
);

let svg = '';
try {
  svg = fs.readFileSync(svgPath, 'utf8');
  const ariaAttrs = ariaLabel
    ? ` aria-label="${ariaLabel}" role="img"`
    : ' aria-hidden="true" focusable="false"';
  svg = svg
    .replace(
      /<svg([^>]*)>/i,
      `<svg$1 width="${size}" height="${size}" stroke-width="1.5"${ariaAttrs} class="inline-block ${cls}">`,
    )
    .replace(/\sfill="(?!none)[^"]*"/g, ' fill="currentColor"');
} catch {
  console.warn(`[Icon] Phosphor icon not found: ${name}`);
}
---

<Fragment set:html={svg} />
